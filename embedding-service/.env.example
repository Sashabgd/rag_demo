REDIS_URL=redis://localhost:7379
RERANKER_LOCAL_MODEL=BAAI/bge-reranker-v2-m3

# Optional: enables the Cohere reranker option in /search (rerankType=COHERE).
# Without it, Cohere requests fall back to plain KNN order (rerankType=NONE).
RERANK_API_TOKEN=
RERANKER_COHERE_MODEL=rerank-v4.0-pro
RERANK_API_URL=https://api.cohere.com/v1/rerank
