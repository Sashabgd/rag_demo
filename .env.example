# Kopiraj u .env u root folderu:  cp .env.example .env
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: enables the Cohere reranker option (UI bira NONE / LOCAL / COHERE).
# Bez tokena, COHERE odabir gracefully fallback-uje na NONE (KNN redosled).
RERANK_API_TOKEN=
RERANKER_COHERE_MODEL=rerank-v4.0-pro
RERANK_API_URL=https://api.cohere.com/v1/rerank
